{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": false,
    "baseUrl": ".",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "typeRoots": [
      "./node_modules/@types",
      "../node_modules/@types"
    ],
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
