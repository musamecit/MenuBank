# Bu dosyayı commit ETMEYİN; sadece şablon.
# GitHub Actions için: db.*.supabase.co (direct) KULLANMAYIN — IPv6. Session pooler URI gerekir.
# Supabase → Connect → Session pooler (host ...pooler.supabase.com:5432).
#
# GitHub: Settings → Secrets → Actions → SOURCE_DATABASE_URL ve TARGET_DATABASE_URL
#
# Yerel Mac (IPv6 varsa direct çalışabilir). GitHub Actions için her zaman pooler URI kullanın.
#   export PGSSLMODE=require
#   export SOURCE_DATABASE_URL='postgres://postgres.PRODREF:ŞİFRE@aws-0-eu-central-1.pooler.supabase.com:5432/postgres'
#   ./scripts/replica-backup.sh

SOURCE_DATABASE_URL=postgres://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
TARGET_DATABASE_URL=postgres://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
