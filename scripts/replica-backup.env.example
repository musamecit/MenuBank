# Bu dosyayı commit ETMEYİN; sadece şablon.
# GitHub Actions için: db.*.supabase.co (direct) KULLANMAYIN — IPv6. Session pooler URI gerekir.
# Supabase → Connect → Session pooler (host ...pooler.supabase.com:5432).
#
# GitHub: Settings → Secrets → Actions → SOURCE_DATABASE_URL ve TARGET_DATABASE_URL
#
# Yerel deneme:
#   export PGSSLMODE=require
#   export SOURCE_DATABASE_URL='postgresql://postgres:PROD@db.PROD_REF.supabase.co:5432/postgres'
#   export TARGET_DATABASE_URL='postgresql://postgres:BACKUP@db.BACKUP_REF.supabase.co:5432/postgres'
#   ./scripts/replica-backup.sh

SOURCE_DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres
TARGET_DATABASE_URL=postgresql://postgres:PASSWORD@db.yyyyyyyyyyyy.supabase.co:5432/postgres
